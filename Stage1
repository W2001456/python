import urllib.request
import urllib.parse
import sys
import os


def download_file(url, save_path=None):
    """
    Core download function
    :param url: URL address of the remote file
    :param save_path: Local save path (optional, extract filename from URL by default)
    :return: Return True if download succeeds, False if fails
    """
    if save_path is None:

        file_name = os.path.basename(urllib.parse.urlsplit(url).path)

        if not file_name:
            file_name = "downloaded_file"
        save_path = file_name

    try:

        print(f"Starting download: {url}")
        print(f"Save path: {os.path.abspath(save_path)}")

        # urlretrieve is a built-in download function of urllib, directly write URL content to local file
        urllib.request.urlretrieve(url, save_path)

        print(f"Download completed! File saved to: {os.path.abspath(save_path)}")
        return True

    except urllib.error.URLError as e:
        print(f"Download failed: URL error - {str(e)}")
        return False
    except PermissionError:
        print(f"Download failed: No permission to write to file {save_path}")
        return False
    except Exception as e:
        # Catch other unknown errors
        print(f" Download failed: Unknown error - {str(e)}")
        return False


if __name__ == "__main__":
    # Check if URL parameter is provided
    if len(sys.argv) < 2:
        print("Usage: python3 wget_stage1.py <file URL>")
        print("Example: python3 wget_stage1.py https://example.com/test.png")
        sys.exit(1)

    # Get the URL passed from command line
    target_url = sys.argv[1]

    # Call the download function
    download_file(target_url)
